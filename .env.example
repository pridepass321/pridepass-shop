# Payment — PayPal (preferred when both are set)
PAYMENT_PROVIDER=paypal
PAYPAL_MODE=sandbox
PAYPAL_CLIENT_ID=your_sandbox_client_id
PAYPAL_CLIENT_SECRET=your_sandbox_client_secret

# Payment — Stripe (optional alternative)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

PORT=8765

# Order fulfillment email (print-ready PDF + PNGs sent when payment completes)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=pridepass321@gmail.com
SMTP_PASSWORD=your_gmail_app_password
SMTP_FROM=pridepass321@gmail.com
ORDER_NOTIFY_EMAIL=pridepass321@gmail.com